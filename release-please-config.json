{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "tag-separator": "/",
  "draft-pull-request": true,
  "separate-pull-requests": true,
  "changelog-sections": [
    { "section": "Features", "type": "feat" },
    { "section": "Bug Fixes", "type": "fix" },
    { "section": "Dependencies", "type": "deps" },
    { "section": "Documentation", "type": "docs" },
    { "section": "Miscellaneous Chores", "type": "chore" }
  ],
  "packages": {
    ".": {
      "package-name": "shared-workflows",
      "initial-version": "0.1.0",
      "include-component-in-tag": false,
      "extra-files": [
        { "type": "generic", "path": "examples/ci.yaml" },
        { "type": "generic", "path": "examples/test.yaml" },
        { "type": "generic", "path": "examples/ci-security.yaml" },
        { "type": "generic", "path": "examples/release-npm.yaml" }
      ]
    },
    "actions/setup": {
      "component": "actions/setup",
      "initial-version": "0.1.0",
      "include-component-in-tag": true
    }
  }
}
